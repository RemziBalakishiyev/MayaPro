# Backend API-nin ünvanı (origin, sonda /api OLMADAN).
# Boş buraxsanız tətbiq mock/demo rejimində işləyir.
VITE_API_URL=https://localhost:7088

# Cloudinary şəkil yükləməsi (unsigned upload preset).
# Boş buraxsanız mal formasında köhnə "Şəkil URL" inputu işləyir.
VITE_CLOUDINARY_CLOUD_NAME=remzinincloudu
VITE_CLOUDINARY_UPLOAD_PRESET=sederek_products
